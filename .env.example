# =============================================================================
# BTC Leads Trading Bot — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ─── Binance API Keys ────────────────────────────────────────
# Real API (read-only for data fetching — needs only read permission)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_api_secret_here

# Demo API (for paper trading — get from https://testnet.binancefuture.com)
BINANCE_DEMO_KEY=your_demo_api_key_here
BINANCE_DEMO_SECRET=your_demo_api_secret_here

# ─── Strategy Parameters ─────────────────────────────────────
BTC_TRIGGER_PCT=1.0       # BTC move (%) that triggers entry
TP_PCT=1.0                # Take profit (%)
SL_PCT=0.5                # Stop loss (%)
POSITION_SIZE_USDT=10     # $ per coin per trade
MAX_COINS_PER_TRADE=5     # Max coins to enter simultaneously

# ─── Risk Management ─────────────────────────────────────────
MAX_DAILY_LOSS_USDT=60    # Max daily loss before bot stops
MAX_TRADES_PER_DAY=10     # Max trades per day
MAX_CONSECUTIVE_LOSSES=5  # Stop after N consecutive losses

# ─── Fixed Coins (always traded) ─────────────────────────────
FIXED_COINS=ETHUSDT,DOGEUSDT

# ─── SMTP Email Alerts (optional) ────────────────────────────
# For Gmail: Enable 2FA, then generate an App Password
# https://myaccount.google.com/apppasswords
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_TO=recipient@example.com

# ─── Database ────────────────────────────────────────────────
DB_PATH=trading_bot.db

# ─── Server ──────────────────────────────────────────────────
# Render automatically sets PORT=10000
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO
